# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenRouter LLM API
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_META_MODEL=google/gemma-4-26b-a4b-it:free
OPENROUTER_REASONING_MODEL=google/gemma-4-26b-a4b-it:free

# GitHub Activity Connector
GITHUB_TOKEN=github_pat_...

# Web Search (Tavily) - Optional
TAVILY_API_KEY=

# Mini App Configuration
MINI_APP_URL=http://localhost:5173
TELEGRAM_API_HOST=0.0.0.0
TELEGRAM_API_PORT=8000

# Storage
KNOWLEDGE_DB_PATH=./data/knowledge.db
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=personal-assistant-kb
QDRANT_API_KEY=

# Daemon Configuration
DAEMON_CHECK_INTERVAL_SECONDS=60
DAEMON_INGEST_INTERVAL_MINUTES=15
DAEMON_LOG_LEVEL=INFO
DAEMON_LOG_FILE=./data/daemon.log
DAEMON_PID_FILE=./data/daemon.pid
DAEMON_STATE_FILE=./data/daemon_state.json

# Connectors
GITHUB_ENABLED=true
CONNECTOR_SLACK_ENABLED=false
CONNECTOR_BROWSER_ENABLED=false

# Agents
AGENT_INTEREST_ENABLED=true
AGENT_RESEARCH_ENABLED=true
AGENT_BRAINSTORMING_ENABLED=true

# Application Settings
APP_NAME=Personal Assistant
APP_TIMEZONE=UTC
APP_LANGUAGE=en

# Development
DEBUG=false
