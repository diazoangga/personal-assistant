# OpenRouter API Key (required for both LLM and embeddings)
# Uses: Gemma-4-26b-a4b-it for text generation, Qwen3-embedding-8b for embeddings
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# GitHub Token (for activity monitoring)
GITHUB_TOKEN=github_pat_your-token-here

# Slack tokens (for Slack gateway and daemon monitoring)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# Qdrant vector DB configuration (optional, defaults to localhost)
QDRANT_HOST=localhost
QDRANT_PORT=6333
