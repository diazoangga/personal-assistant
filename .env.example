# ============================================================================
# Personal Assistant Configuration via Environment Variables
# ============================================================================
# All configuration is now environment-driven for flexibility and security.
# Copy this file to .env and fill in your values.

# ============================================================================
# REQUIRED: OpenRouter API Configuration
# ============================================================================
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ============================================================================
# LLM Model Selection
# ============================================================================
# meta_model: general-purpose reasoning (safety, critique, interest extraction)
# reasoning_model: advanced reasoning (future phases)
# embedding_model: for vector embeddings
# brainstorming_model: specific model for brainstorming agent (empty = uses meta_model)
OPENROUTER_META_MODEL=google/gemma-4-26b-a4b-it:free
OPENROUTER_REASONING_MODEL=google/gemma-4-26b-a4b-it:free
OPENROUTER_EMBEDDING_MODEL=qwen/qwen3-embedding-8b
BRAINSTORMING_MODEL=

# LLM Rate Limiting & Retry
OPENROUTER_RATE_LIMIT_PER_MINUTE=60
OPENROUTER_RATE_LIMIT_PER_DAY=1000
OPENROUTER_MAX_RETRIES=3
OPENROUTER_RETRY_BASE_DELAY=1.0

# ============================================================================
# REQUIRED: API Keys & Tokens
# ============================================================================
# GitHub token for activity monitoring (required for ingest)
GITHUB_TOKEN=github_pat_your-token-here

# Slack tokens (optional, for Slack monitoring)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# Tavily API key (optional, for web_search in brainstorming agent)
TAVILY_API_KEY=tvly-your-key-here

# Semantic Scholar API key (optional, for research agent citation lookup)
# Without key: ~100 req/5 min. With key: much higher limits.
# Get free key: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# OpenAlex API key (optional, free fallback when Semantic Scholar is rate-limited)
# OpenAlex is free and doesn't require auth, but you can set this for higher limits.
# Get key: https://openalex.org/
OPENALEX_API_KEY=

# ============================================================================
# Storage Configuration
# ============================================================================
# Qdrant vector database (for semantic search)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=personal-assistant-kb

# SQLite knowledge store
KNOWLEDGE_DB_PATH=./data/knowledge.db

# ============================================================================
# Ingest Pipeline Configuration
# ============================================================================
# GitHub connector
GITHUB_ENABLED=true
GITHUB_POLL_INTERVAL_MINUTES=15

# arXiv connector
ARXIV_ENABLED=true
ARXIV_CATEGORIES=cs.AI,cs.LG,cs.CL
ARXIV_MAX_RESULTS=50

# ============================================================================
# Agent Configuration
# ============================================================================
# Brainstorming Agent (LangGraph + tool-calling + self-critique)
BRAINSTORMING_TEMPERATURE=0.7
BRAINSTORMING_MAX_ITERATIONS=5

# Interest Agent
INTEREST_BATCH_SIZE=5
INTEREST_MIN_CONFIDENCE=0.6
INTEREST_EMBEDDING_CACHE_ENABLED=true

# ============================================================================
# Knowledge Storage Configuration
# ============================================================================
# Quality-based knowledge entry storage
KNOWLEDGE_QUALITY_THRESHOLD=0.65
KNOWLEDGE_AUTO_EMBED=false
KNOWLEDGE_MAX_ENTRIES_PER_USER=1000

# ============================================================================
# Conversation Management
# ============================================================================
CONVERSATION_SESSION_LIMIT=100
CONVERSATION_AUTO_CREATE=true
CONVERSATION_PERSIST_ACROSS_RESTARTS=true

# ============================================================================
# Daemon Service Configuration
# ============================================================================
DAEMON_CHECK_INTERVAL_SECONDS=60
DAEMON_INGEST_INTERVAL_MINUTES=15
DAEMON_LOG_LEVEL=INFO
DAEMON_LOG_FILE=./data/daemon.log
DAEMON_PID_FILE=./data/daemon.pid
DAEMON_STATE_FILE=./data/daemon_state.json

# ============================================================================
# Connectors: Slack
# ============================================================================
CONNECTOR_SLACK_ENABLED=false
CONNECTOR_SLACK_CHANNELS=#general
CONNECTOR_SLACK_INCLUDE_DMS=true

# ============================================================================
# Connectors: Browser History
# ============================================================================
CONNECTOR_BROWSER_ENABLED=false
CONNECTOR_BROWSER_BROWSERS=chrome,firefox
CONNECTOR_BROWSER_TRACK_SEARCHES=true
CONNECTOR_BROWSER_TRACK_PAGE_VISITS=true
CONNECTOR_BROWSER_MIN_TIME_ON_PAGE=2
CONNECTOR_BROWSER_EXCLUDE_DOMAINS=localhost,127.0.0.1

# ============================================================================
# Application Settings
# ============================================================================
APP_NAME=My AI Assistant
APP_TIMEZONE=UTC
APP_LANGUAGE=en

# Seed topics for interest modeling (comma-separated)
SEED_TOPICS=artificial intelligence,machine learning,software engineering,python,distributed systems
